---
import { UserMenu } from "@/components/UserMenu";

const { user } = Astro.locals;
---

<nav
  class="bg-foreground/95 text-primary-foreground mx-4 mt-4 flex items-center justify-between rounded-xl px-5 py-2.5 text-sm shadow-md"
>
  <a href="/" class="font-['Playfair_Display'] text-lg font-semibold tracking-wide">Fermenta</a>
  {
    user ? (
      <div class="flex items-center gap-4">
        <a href="/batches" class="hover:text-secondary transition-colors">
          Batches
        </a>
        <UserMenu email={user.email ?? ""} client:load />
      </div>
    ) : (
      <div class="flex gap-4">
        <a href="/auth/signin" class="hover:text-secondary transition-colors">
          Sign in
        </a>
        <a href="/auth/signup" class="hover:text-secondary transition-colors">
          Sign up
        </a>
      </div>
    )
  }
</nav>
