---
import Topbar from "@/components/Topbar.astro";
---

<div class="bg-background min-h-screen w-full">
  <Topbar />

  <!-- Hero section -->
  <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-24 text-center sm:py-32 lg:py-40">
    <h1 class="text-foreground mb-6 text-5xl font-bold sm:text-6xl lg:text-7xl">Fermenta</h1>
    <p class="text-muted-foreground mb-10 max-w-2xl text-lg sm:text-xl">
      Plan every batch with confidence. Track your winemaking from first crush to final pour.
    </p>
    <div class="flex flex-col gap-4 sm:flex-row">
      <a
        href="/auth/signin"
        class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-medium transition-colors"
      >
        Sign In
      </a>
      <a
        href="/auth/signup"
        class="bg-secondary text-secondary-foreground hover:bg-secondary/80 inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-medium transition-colors"
      >
        Sign Up
      </a>
    </div>
  </div>

  <!-- Feature cards -->
  <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 pb-24 sm:grid-cols-3">
    <div class="bg-muted rounded-xl p-6 shadow-sm">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-primary mb-4"
      >
        <path
          d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"
        ></path>
        <path
          d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"
        ></path>
      </svg>
      <h3 class="text-foreground mb-2 text-lg font-semibold">Batch Calculation</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Calculate sugar, yeast, and volumes for every batch. Get it right the first time.
      </p>
    </div>

    <div class="bg-muted rounded-xl p-6 shadow-sm">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-primary mb-4"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
        <path d="m9 12 2 2 4-4"></path>
      </svg>
      <h3 class="text-foreground mb-2 text-lg font-semibold">Input Validation</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Catch mistakes before they cost you a batch. Smart validation based on real winemaking rules.
      </p>
    </div>

    <div class="bg-muted rounded-xl p-6 shadow-sm">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-primary mb-4"
      >
        <path d="M8 2v4"></path>
        <path d="M16 2v4"></path>
        <rect width="18" height="18" x="3" y="4" rx="2"></rect>
        <path d="M3 10h18"></path>
      </svg>
      <h3 class="text-foreground mb-2 text-lg font-semibold">Process Planning</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Track your fermentation timeline, ingredients, and tasting notes in one place.
      </p>
    </div>
  </div>
</div>
