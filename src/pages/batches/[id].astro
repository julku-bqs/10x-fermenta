---
import AppLayout from "@/layouts/AppLayout.astro";
import { BatchForm } from "@/components/batches/BatchForm";
import { DeleteBatchDialog } from "@/components/batches/DeleteBatchDialog";
import { createClient } from "@/lib/supabase";
import type { Batch } from "@/types";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const UUID_REGEX = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

if (!supabase || !id || !UUID_REGEX.test(id)) {
  return new Response(null, { status: 404 });
}

// eslint-disable-next-line @typescript-eslint/no-unsafe-assignment
const { data, error } = await supabase.from("batches").select("*").eq("id", id).single();

if (error || !data) {
  return new Response(null, { status: 404 });
}

const batch = data as Batch;
---

<AppLayout title={batch.name}>
  <a href="/batches" class="text-muted-foreground hover:text-foreground mb-6 inline-block text-sm">← My Batches</a>

  <BatchForm client:load mode="edit" title={batch.name} initialData={batch} />

  <div class="mt-8 flex justify-end gap-3 border-t pt-6">
    <a
      href={`/batches/new?from=${batch.id}`}
      class="inline-flex items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50"
    >
      Duplicate as New
    </a>
    <DeleteBatchDialog client:load batchId={batch.id} batchName={batch.name} />
  </div>
</AppLayout>
