---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="My Batches">
  <div class="mx-auto max-w-4xl px-4 py-10">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-2xl font-bold text-gray-900">My Batches</h1>
      <a
        href="/batches/new"
        class="inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-xs hover:bg-blue-700"
      >
        + New Batch
      </a>
    </div>
    <p class="text-gray-500">Batch list coming soon.</p>
  </div>
</Layout>
