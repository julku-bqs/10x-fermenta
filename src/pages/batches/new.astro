---
import AppLayout from "@/layouts/AppLayout.astro";
import { BatchForm } from "@/components/batches/BatchForm";
import { createClient } from "@/lib/supabase";
import type { Batch } from "@/types";

const sourceBatchId = Astro.url.searchParams.get("from");
const UUID_REGEX = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

let initialData: Batch | undefined;
let pageTitle = "New Batch";

if (sourceBatchId && UUID_REGEX.test(sourceBatchId)) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment
    const { data, error } = await supabase.from("batches").select("*").eq("id", sourceBatchId).single();
    if (!error && data) {
      const sourceBatch = data as Batch;
      initialData = {
        ...sourceBatch,
        name: "",
        batch_date: "",
      };
      pageTitle = `New Batch (from ${sourceBatch.name})`;
    }
  }
}
---

<AppLayout title={pageTitle}>
  <a href="/batches" class="text-muted-foreground hover:text-foreground mb-6 inline-block text-sm">← My Batches</a>
  <BatchForm client:load mode="create" title={pageTitle} initialData={initialData} />
</AppLayout>
